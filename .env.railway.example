# Railway Environment Variables
PORT=3001
NODE_ENV=production
DB_PATH=/data/chess.db

# Generate a secure JWT secret (64 random hex characters)
# You can generate one with: openssl rand -hex 64
JWT_SECRET=your-secure-jwt-secret-here-generate-with-openssl-rand-hex-64

# Generate a secure encryption key (32 bytes = 64 hex chars)
# You can generate one with: openssl rand -hex 32
ENCRYPTION_KEY=your-secure-encryption-key-here