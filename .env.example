# UCX Chess Platform Configuration
# For Railway: Set these as environment variables in your project settings

PORT=3001
NODE_ENV=production

# Database path (use persistent volume on Railway/Render)
DB_PATH=./data/chess.db

# JWT Secret - Generate with: openssl rand -hex 64
# Example: JWT_SECRET=a1b2c3d4e5f6... (64 random hex characters)
JWT_SECRET=

# Encryption key - Generate with: openssl rand -hex 32
# Example: ENCRYPTION_KEY=a1b2c3d4e5f6... (32 random hex characters)  
ENCRYPTION_KEY=
