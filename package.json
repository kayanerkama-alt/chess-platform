{
  "name": "chess-platform",
  "version": "1.0.0",
  "description": "UCX Chess Platform - Founded in 2023 by Kayan Erkama. A fast, privacy-focused chess platform with multiple themes, piece styles, and AI opponents.",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"yarn dev:server\" \"yarn dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "cd client && vite",
    "build": "cd client && vite build",
    "start": "node server/index.js",
    "lint": "echo 'No lint configured'"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Kayan Erkama",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "better-sqlite3": "^9.4.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.3.1",
    "crypto-js": "^4.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
